{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -re '.tool_input.file_path' | grep -qE '\\.nix$' && cd /home/shimo/tsurara && task fmt || true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"現在の作業ホスト: $(hostname)\""
          }
        ]
      }
    ]
  }
}
